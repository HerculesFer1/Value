# Copie para .env e preencha. NUNCA versione o .env real.
# Dados de clientes sob sigilo profissional (art. 34, VII, EOAB, e LGPD).

# ---- Banco (PostgreSQL 16) ----
# IMPORTANTE: colunas monetárias usam NUMERIC, jamais DOUBLE PRECISION.
POSTGRES_USER=value
POSTGRES_PASSWORD=change-me
POSTGRES_DB=value
DATABASE_URL=postgresql+psycopg://value:change-me@localhost:5432/value

# ---- Cifragem em repouso de dados pessoais (CPF, RG, endereço) ----
# Chave de 32 bytes base64. Gere localmente; guarde fora do repositório.
FIELD_ENCRYPTION_KEY=

# ---- API ----
API_HOST=127.0.0.1
API_PORT=8000
# Sistema é on-premise. NÃO expor à internet pública.
ALLOWED_ORIGINS=http://localhost:5173
